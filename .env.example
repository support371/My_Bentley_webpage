# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set false in production
PORT=5000

# ─── Security (REQUIRED — change before any deployment) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-min-32-characters-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Session cookies — set true for HTTPS deployments
COOKIE_SECURE=false

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev/local)
DATABASE_URL=sqlite+aiosqlite:///./itwin_ops.db

# PostgreSQL (staging/production) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/itwin_ops?sslmode=require

# ─── Initial Admin Credentials (seeded on first boot) ────────────────────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe!2024   # Must be changed after first login

# ─── Webhook Security ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your-webhook-secret-here
SKIP_SIGNATURE_VERIFY=true             # MUST be false in production

# ─── Bentley iTwin API ────────────────────────────────────────────────────────
# Register at https://developer.bentley.com/
BENTLEY_CLIENT_ID=
BENTLEY_CLIENT_SECRET=
BENTLEY_AUTHORITY=https://ims.bentley.com
BENTLEY_API_BASE=https://api.bentley.com
BENTLEY_SCOPE=itwins:read imodels:read webhooks:read webhooks:modify

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to your production domain to restrict CORS origins
# PUBLIC_BASE_URL=https://your-domain.example.com

# ─── Alerting (optional) ──────────────────────────────────────────────────────
# Slack incoming webhook URL
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# SMTP relay for email alerts (format: smtp://user:pass@host:587)
# ALERT_EMAIL_SMTP=smtp://alerts@example.com:password@smtp.example.com:587

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
