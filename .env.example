# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set false in production
PORT=5000

# ─── Security (REQUIRED — change before any deployment) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-min-32-characters-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Session cookies — set true for HTTPS deployments
COOKIE_SECURE=false

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev/local)
DATABASE_URL=sqlite+aiosqlite:///./itwin_ops.db

# PostgreSQL (staging/production) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/itwin_ops?sslmode=require

# ─── Initial Admin Credentials (seeded on first boot) ────────────────────────
# ─── App Settings ──────────────────────────────────────────────────────────────
APP_NAME="Bentley iTwin Operations Center"
ENVIRONMENT=development        # development | production
DEBUG=True
PORT=5000
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-64-char-secret-here

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev/local) — resets on container restart:
DATABASE_URL=sqlite+aiosqlite:///./itwin_ops.db
# PostgreSQL (production recommended):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=disable

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=480
COOKIE_SECURE=False            # Set to True in production (HTTPS only)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe!2024   # Must be changed after first login

# ─── Webhook Security ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your-webhook-secret-here
SKIP_SIGNATURE_VERIFY=true             # MUST be false in production

# ─── Bentley iTwin API ────────────────────────────────────────────────────────
# Register at https://developer.bentley.com/
BENTLEY_CLIENT_ID=
BENTLEY_CLIENT_SECRET=
BENTLEY_AUTHORITY=https://ims.bentley.com
BENTLEY_API_BASE=https://api.bentley.com
BENTLEY_SCOPE=itwins:read imodels:read webhooks:read webhooks:modify

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to your production domain to restrict CORS origins
# PUBLIC_BASE_URL=https://your-domain.example.com

# ─── Alerting (optional) ──────────────────────────────────────────────────────
# Slack incoming webhook URL
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# SMTP relay for email alerts (format: smtp://user:pass@host:587)
# ALERT_EMAIL_SMTP=smtp://alerts@example.com:password@smtp.example.com:587

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
# OAuth scope - adjust if your Service Application has a narrower grant
BENTLEY_SCOPE=itwins:read imodels:read webhooks:read webhooks:modify

# Override Bentley endpoints only if using a non-production environment
# BENTLEY_AUTHORITY=https://ims.bentley.com
# BENTLEY_API_BASE=https://api.bentley.com

# ─── Public URL (for webhook callback registration) ────────────────────────────
# Set this to your deployed app URL. Used by diagnostics and Bentley webhook setup.
# Example: PUBLIC_BASE_URL=https://your-app.replit.app
PUBLIC_BASE_URL=

# ─── Alert Email (optional) ────────────────────────────────────────────────────
# Required only for email alert delivery. Multi-channel (Slack, Discord, PagerDuty)
# is configured per-rule in the Admin UI — no env vars needed for those.
ALERT_EMAIL_SMTP=
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASS=
ALERT_EMAIL_FROM=

# ─── Observability (optional) ──────────────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
# DD_API_KEY=your-datadog-api-key
