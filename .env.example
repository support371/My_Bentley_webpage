# ─── App Settings ──────────────────────────────────────────────────────────────
APP_NAME="Bentley iTwin Operations Center"
ENVIRONMENT=development        # development | production
DEBUG=True
PORT=5000
SECRET_KEY=your-random-32-char-secret-here

# ─── Database ──────────────────────────────────────────────────────────────────
# Replit provides this automatically when a PostgreSQL DB is provisioned.
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=disable

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=480
COOKIE_SECURE=False            # Set to True in production (HTTPS only)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=admin123

# ─── Webhook Ingestion ─────────────────────────────────────────────────────────
# Required for production. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=
# Set to False in production to enforce HMAC-SHA256 signature verification
SKIP_SIGNATURE_VERIFY=True

# ─── Bentley Platform ──────────────────────────────────────────────────────────
# Obtain from: https://developer.bentley.com -> Applications -> Service Application
BENTLEY_CLIENT_ID=
BENTLEY_CLIENT_SECRET=

# OAuth scope - adjust if your Service Application has a narrower grant
BENTLEY_SCOPE=itwins:read imodels:read webhooks:read webhooks:modify

# Override Bentley endpoints only if using a non-production environment
# BENTLEY_AUTHORITY=https://ims.bentley.com
# BENTLEY_API_BASE=https://api.bentley.com

# ─── Public URL (for webhook callback registration) ────────────────────────────
# Set this to your deployed app URL so the diagnostics page shows the correct
# callback URL to register in the Bentley Developer Portal.
# Example: PUBLIC_BASE_URL=https://your-app.replit.app
PUBLIC_BASE_URL=

# ─── Alerting (optional) ───────────────────────────────────────────────────────
ALERT_SLACK_WEBHOOK=
ALERT_EMAIL_SMTP=
