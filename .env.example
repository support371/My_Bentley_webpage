# ─── Application ────────────────────────────────────────
ENVIRONMENT=development        # development | production
DEBUG=true
PORT=5000
SECRET_KEY=change-me-min-32-characters-random-string

# ─── Database ────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./itwin_ops.db
# For Postgres: postgresql+asyncpg://user:pass@host:5432/dbname

# ─── Initial Admin ───────────────────────────────────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=admin123

# ─── Webhook Security ────────────────────────────────────
WEBHOOK_SECRET=your-webhook-secret-here
SKIP_SIGNATURE_VERIFY=true     # Set to false in production

# ─── Bentley API ─────────────────────────────────────────
BENTLEY_CLIENT_ID=
BENTLEY_CLIENT_SECRET=

# ─── Alerts (optional) ───────────────────────────────────
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
